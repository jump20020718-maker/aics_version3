{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://internal.example.com/schemas/rag_schema_v3.json",
  "title": "跨境进口家电 AI 客服 RAG 文档 Schema v3",
  "description": "对 rag_source_docs_v2.jsonl 的统一 Schema。核心用户：中国大陆用户。业务背景：从东南亚(SG/MY)或欧美渠道进口海外版家电，不支持七天无理由退换，仅支持质量问题退换。相较 v2：(1) 把 country_scope 拆成三个语义字段 version_country/sales_regions/supported_use_countries/valid_regions；(2) 引入 source_of_truth_tier + confidence_ceiling；(3) 引入 locale / data_provenance / created_at 等元数据；(4) 把 priority_topic 字符串改为 priority_topics 数组；(5) 把 replace_with_real_doc 从 Y/N 字符串改为布尔；(6) 新增 3 个 doc_type：import_warranty_card、shipping_eta_card、travel_use_card；(7) 把单一 risk_level 拆为 subject_risk_level + data_risk_level。",
  "version": "3.0.0",
  "updated_at": "2026-04-15",

  "type": "object",
  "required": [
    "doc_id",
    "doc_type",
    "domain",
    "title",
    "priority_topics",
    "source_type",
    "replace_with_real_doc",
    "locale",
    "source_of_truth_tier",
    "confidence_ceiling",
    "data_provenance",
    "subject_risk_level",
    "data_risk_level",
    "created_at",
    "updated_at",
    "version"
  ],
  "additionalProperties": true,

  "properties": {
    "doc_id": {
      "type": "string",
      "pattern": "^(DOC|SNP)-[A-Za-z0-9\\-_]+$",
      "description": "文档唯一标识，全局唯一。允许大小写混合（如 'DOC-SKU-DELO-Bean-US-FACT'）。"
    },
    "doc_type": {
      "type": "string",
      "enum": [
        "sku_fact_card",
        "compatibility_install_card",
        "service_need_profile",
        "warranty_region_policy",
        "damage_signoff_sop",
        "price_dispute_policy",
        "import_warranty_card",
        "shipping_eta_card",
        "travel_use_card"
      ],
      "description": "文档类型。v3 新增 3 个：import_warranty_card（进口保修卡）、shipping_eta_card（运输时效说明卡）、travel_use_card（带出国使用卡）。"
    },
    "domain": {
      "type": "string",
      "pattern": "^KD[0-9]{2}$",
      "description": "领域编号，KD01-KD11。"
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "priority_topics": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "电压/频率/插头兼容",
          "安装条件",
          "保修地域",
          "签收破损",
          "降价争议",
          "多场景画像",
          "进口保修",
          "运输时效",
          "带出国使用",
          "销售规则",
          "合规认证"
        ]
      },
      "minItems": 1,
      "uniqueItems": true,
      "description": "v3 由原字符串 priority_topic（以 | 分隔）拆成数组。不得含重复项。"
    },
    "source_type": {
      "type": "string",
      "enum": ["synthetic_seed", "supplier_doc", "brand_official", "internal_policy", "user_contributed"],
      "description": "文档来源类型。v2 checklist 原有的 'synthetic_backlog' 已并入 collection_status 字段，不再使用。"
    },
    "replace_with_real_doc": {
      "type": "boolean",
      "description": "v3 由 'Y'/'N' 字符串改为真布尔。true 表示该 doc 上线前必须被真实文档替换。"
    },
    "locale": {
      "type": "string",
      "enum": ["zh-CN", "zh-TW", "en-US", "en-SG"],
      "description": "v3 新增。该 doc 文本的语言/地区。本项目所有 doc 默认 zh-CN。"
    },
    "source_of_truth_tier": {
      "type": "string",
      "enum": ["tier1_official", "tier2_supplier", "tier3_synthetic", "tier4_user_generated"],
      "description": "信任度分层。tier1_official=品牌官方/发票/电商平台后端；tier2_supplier=进口商/代理商文档；tier3_synthetic=合成种子；tier4_user_generated=客服对话/用户评论。"
    },
    "confidence_ceiling": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "基于 tier 推导的置信度上限。tier1=1.0 / tier2=0.8 / tier3=0.5 / tier4=0.3。"
    },
    "data_provenance": {
      "type": "object",
      "required": ["origin", "collected_at", "collector"],
      "properties": {
        "origin": {"type": "string"},
        "collected_at": {"type": "string", "format": "date-time"},
        "collector": {"type": "string"},
        "review_status": {"type": "string", "enum": ["unreviewed", "auto_reviewed", "human_reviewed"]},
        "reviewer": {"type": "string"}
      }
    },
    "subject_risk_level": {
      "type": "string",
      "enum": ["低", "中", "高", "极高"],
      "description": "v3 由 risk_level 拆出。标示该主题的业务风险（例如 compatibility=极高；降价争议=高）。"
    },
    "data_risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "high_synthetic_only"],
      "description": "v3 由 risk_level 拆出。标示该 doc 数据本身的质量风险（例如 synthetic_seed 的最高级别就是 high_synthetic_only）。"
    },
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "version": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "expires_at": {"type": ["string", "null"], "format": "date-time", "description": "仅政策类（warranty/price_dispute/shipping_eta）需要 TTL；其余字段为空。"},

    "sku_id": {"type": "string", "pattern": "^SKU-[A-Za-z0-9\\-]+$"},
    "brand": {"type": "string"},
    "brand_id": {"type": "string", "pattern": "^BR[0-9]{2}$"},
    "category": {"type": "string"},
    "category_id": {"type": "string", "pattern": "^CAT[0-9]{2}$"},
    "model": {"type": "string"},

    "version_country": {
      "type": "string",
      "enum": ["US", "CA", "UK", "EU", "JP", "AU", "AE", "SG", "CN", "MY"],
      "description": "v3 由 country_scope 拆出（仅 sku_fact_card）：该 SKU 的设计版本/原始销售市场。"
    },
    "sales_regions": {
      "type": "array",
      "items": {"type": "string", "enum": ["CN-mainland", "HK", "TW", "SG", "MY", "US", "EU", "UK", "JP", "AU", "AE"]},
      "minItems": 1,
      "description": "v3 新增（仅 sku_fact_card）：实际在哪些地区销售。跨境进口家电默认 ['CN-mainland']。"
    },
    "supported_use_countries": {
      "type": "array",
      "items": {"type": "string", "enum": ["CN-mainland", "HK", "TW", "US", "CA", "UK", "EU", "JP", "AU", "AE", "SG", "MY"]},
      "minItems": 1,
      "description": "v3 由 country_scope 拆出（仅 compatibility_install_card）：已经准备好'在该国使用'的答案的国家列表。默认必须包含 'CN-mainland'。"
    },
    "warranty_scope_type": {
      "type": "string",
      "enum": ["importer_only", "importer_with_brand_support", "brand_global", "brand_regional"],
      "description": "v3 新增（仅 warranty_region_policy 和 import_warranty_card）：进口商保修还是品牌全球保修。默认 importer_only。"
    },
    "valid_regions": {
      "type": "array",
      "items": {"type": "string"},
      "description": "v3 由 country_scope 拆出（仅 warranty_region_policy）：保修在哪些地区有效。"
    },

    "facts": {
      "type": "object",
      "properties": {
        "product_name": {"type": "string"},
        "subcategory": {"type": "string"},
        "origin_country": {"type": "string"},
        "rated_voltage": {"type": "string"},
        "rated_frequency": {"type": "string"},
        "plug_type": {"type": "string"},
        "power_watt": {"type": "number"},
        "certification_mark": {"type": "string"},
        "dimensions_cm": {"type": "string"},
        "installation_type": {"type": "string"},
        "top_service_topics": {"type": "array", "items": {"type": "string"}},
        "china_usability": {"type": "string", "enum": ["direct", "need_adapter", "need_transformer", "need_transformer_and_adapter", "not_recommended"]},
        "china_voltage_note": {"type": "string"},
        "china_plug_adapter": {"type": "string"},
        "warranty_type": {"type": "string", "enum": ["importer_only", "importer_with_brand_support", "brand_global"]},
        "warranty_duration_days": {"type": "integer", "minimum": 0},
        "return_policy_type": {"type": "string", "enum": ["quality_only", "7_day_no_reason", "quality_only_extended"]},
        "import_channel": {"type": "string", "enum": ["official_distributor", "parallel_import", "gray_market", "bonded_warehouse"]},
        "sales_rule_return": {"type": "string"},
        "sales_rule_return_window_days": {"type": "integer", "minimum": 0}
      }
    },

    "compatibility_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["country", "verdict", "required_household_power", "required_plug", "explain"],
        "properties": {
          "country": {"type": "string"},
          "verdict": {"type": "string", "enum": ["compatible", "need_adapter", "need_transformer", "need_transformer_and_adapter", "manual_review", "not_recommended"]},
          "required_household_power": {"type": "string"},
          "required_plug": {"type": "string"},
          "explain": {"type": "string"},
          "recommended_accessory": {"type": "string"}
        }
      }
    },

    "installation_requirements": {
      "type": "object",
      "properties": {
        "space_requirement": {"type": "string"},
        "clearance": {"type": "string"},
        "water_inlet_required": {"type": ["boolean", "string"], "description": "true/false 或自由文本（如 '部分烘干机Y'）"},
        "drainage_required": {"type": ["boolean", "string"]},
        "exhaust_required": {"type": ["boolean", "string"]},
        "dedicated_circuit_required": {"type": ["string", "boolean"]},
        "power_note": {"type": "string"},
        "pre_install_checklist": {"type": "string"}
      }
    },

    "warranty_mode": {"type": "string", "enum": ["same_region_only", "importer_only", "global", "brand_regional", "regional_only", "global_limited", "global_limited_small_appliance"]},
    "policy_rows": {"type": "array", "items": {"type": "array"}},
    "default_boundary": {"type": "string"},
    "linked_sku_ids": {"type": "array", "items": {"type": "string"}},

    "rule": {"type": "object"},

    "core_needs": {"type": "string"},
    "problem_space": {"type": "string"},
    "triage_hint": {"type": "string"},

    "import_info": {
      "type": "object",
      "description": "import_warranty_card 的主要字段。",
      "properties": {
        "importer_name": {"type": "string"},
        "importer_type": {"type": "string", "enum": ["official_distributor", "parallel_import", "bonded_warehouse"]},
        "warranty_scope_type": {"type": "string", "enum": ["importer_only", "importer_with_brand_support", "brand_global"]},
        "warranty_duration_days": {"type": "integer"},
        "service_network": {"type": "string"},
        "rma_process": {"type": "string"},
        "excluded_failures": {"type": "array", "items": {"type": "string"}},
        "customer_pay_items": {"type": "array", "items": {"type": "string"}},
        "cross_check_with_brand": {"type": "string"}
      }
    },

    "shipping_info": {
      "type": "object",
      "description": "shipping_eta_card 的主要字段。",
      "properties": {
        "origin_hub": {"type": "string"},
        "destination_hub": {"type": "string", "enum": ["CN-mainland"]},
        "transport_mode": {"type": "string", "enum": ["sea", "air", "bonded_warehouse_prestocked"]},
        "typical_eta_days_min": {"type": "integer"},
        "typical_eta_days_max": {"type": "integer"},
        "customs_clearance_days": {"type": "integer"},
        "last_mile_days": {"type": "integer"},
        "script_why_slow": {"type": "string"},
        "expedite_available": {"type": "boolean"},
        "expedite_cost_script": {"type": "string"}
      }
    },

    "travel_info": {
      "type": "object",
      "description": "travel_use_card 的主要字段：中国用户把该小电器带出国使用的场景。",
      "properties": {
        "target_countries": {"type": "array", "items": {"type": "string"}},
        "per_country_verdict": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["country", "verdict", "explain"],
            "properties": {
              "country": {"type": "string"},
              "verdict": {"type": "string", "enum": ["compatible", "need_adapter", "need_transformer", "need_transformer_and_adapter", "not_recommended"]},
              "explain": {"type": "string"},
              "recommended_accessory": {"type": "string"}
            }
          }
        },
        "battery_iata_note": {"type": "string"},
        "hand_carry_note": {"type": "string"}
      }
    },

    "collection_status": {
      "type": "string",
      "enum": ["pending", "collecting", "verified", "rejected"],
      "description": "仅 real_doc_checklist 使用，用来区分待替换的文档收集进度。"
    }
  },

  "allOf": [
    {
      "if": {"properties": {"doc_type": {"const": "sku_fact_card"}}},
      "then": {
        "required": ["sku_id", "brand", "category", "model", "version_country", "sales_regions", "facts"],
        "properties": {
          "facts": {
            "required": ["china_usability", "warranty_type", "return_policy_type", "import_channel"]
          }
        }
      }
    },
    {
      "if": {"properties": {"doc_type": {"const": "compatibility_install_card"}}},
      "then": {
        "required": ["sku_id", "brand", "category", "supported_use_countries", "compatibility_rules"],
        "properties": {
          "supported_use_countries": {
            "contains": {"const": "CN-mainland"},
            "description": "默认必含 CN-mainland，因为核心用户是中国大陆。"
          }
        }
      }
    },
    {
      "if": {"properties": {"doc_type": {"const": "warranty_region_policy"}}},
      "then": {
        "required": ["brand", "category", "warranty_scope_type", "valid_regions", "linked_sku_ids"]
      }
    },
    {
      "if": {"properties": {"doc_type": {"const": "service_need_profile"}}},
      "then": {
        "required": ["sku_id", "brand", "category", "core_needs", "problem_space", "triage_hint"]
      }
    },
    {
      "if": {"properties": {"doc_type": {"const": "damage_signoff_sop"}}},
      "then": {
        "required": ["category", "rule"]
      }
    },
    {
      "if": {"properties": {"doc_type": {"const": "price_dispute_policy"}}},
      "then": {
        "required": ["category", "rule", "expires_at"]
      }
    },
    {
      "if": {"properties": {"doc_type": {"const": "import_warranty_card"}}},
      "then": {
        "required": ["sku_id", "brand", "category", "import_info", "expires_at"]
      }
    },
    {
      "if": {"properties": {"doc_type": {"const": "shipping_eta_card"}}},
      "then": {
        "required": ["category", "shipping_info", "expires_at"]
      }
    },
    {
      "if": {"properties": {"doc_type": {"const": "travel_use_card"}}},
      "then": {
        "required": ["sku_id", "brand", "category", "travel_info"]
      }
    },

    {
      "if": {"properties": {"source_of_truth_tier": {"const": "tier1_official"}}},
      "then": {"properties": {"confidence_ceiling": {"const": 1.0}}}
    },
    {
      "if": {"properties": {"source_of_truth_tier": {"const": "tier2_supplier"}}},
      "then": {"properties": {"confidence_ceiling": {"const": 0.8}}}
    },
    {
      "if": {"properties": {"source_of_truth_tier": {"const": "tier3_synthetic"}}},
      "then": {"properties": {"confidence_ceiling": {"const": 0.5}}}
    },
    {
      "if": {"properties": {"source_of_truth_tier": {"const": "tier4_user_generated"}}},
      "then": {"properties": {"confidence_ceiling": {"const": 0.3}}}
    },

    {
      "if": {
        "allOf": [
          {"properties": {"source_type": {"const": "synthetic_seed"}}},
          {"not": {"properties": {"doc_type": {"const": "service_need_profile"}}}}
        ]
      },
      "then": {
        "properties": {
          "replace_with_real_doc": {"const": true},
          "data_risk_level": {"const": "high_synthetic_only"}
        }
      }
    }
  ]
}
