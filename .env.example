# ===== Database =====
DATABASE_URL="file:./dev.db"

# ===== LLM Providers =====
# 智谱
ZHIPU_API_KEY=""
ZHIPU_BASE_URL="https://open.bigmodel.cn/api/paas/v4"

# 硅基流动 (OpenAI 兼容)
SILICONFLOW_API_KEY=""
SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"

# 可选
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ===== Embedding / RAG =====
EMBED_PROVIDER="siliconflow"
EMBED_MODEL="BAAI/bge-m3"
VECTOR_STORE="memory"

# ===== Demo 模式 =====
# 无 API Key 时走 mock LLM provider，保证 demo 可跑
LLM_MOCK_MODE="auto"
